{
  "name": "agentreview",
  "version": "0.1.0",
  "description": "Multi-agent AI code review CLI powered by Anthropic Claude",
  "type": "module",
  "bin": {
    "agentreview": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "prompts",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build && npm run test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "micromatch": "^4.0.8",
    "ora": "^8.1.0",
    "simple-git": "^3.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "code-review",
    "ai",
    "claude",
    "anthropic",
    "cli",
    "multi-agent"
  ],
  "license": "MIT"
}
